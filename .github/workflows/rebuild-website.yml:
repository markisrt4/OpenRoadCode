name: Rebuild documentation website

on:
  push:
    branches:
      - master

jobs:
  notify-website:
    runs-on: ubuntu-latest

    steps:
      - name: Trigger website deployment
        env:
          GH_TOKEN: ${{ secrets.SITE_DISPATCH_TOKEN }}
        run: |
          gh api \
            --method POST \
            repos/markisrt4/openroadcode-site/dispatches \
            -f event_type=openroadcode-updated \
            -f "client_payload[sha]=${GITHUB_SHA}"
